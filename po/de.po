msgid ""
"Accelerates channel zapping by pre-tuning the next, previous and "
"last-watched channel on free FBC tuners."
msgstr ""
"Beschleunigt das Umschalten, indem der nächste, vorherige und zuletzt "
"gesehene Sender auf freien FBC-Tunern vorgetunt wird."

msgid "Enable plugin"
msgstr "Plugin aktivieren"

msgid "Allow tuner allocation (master safety)"
msgstr "Tuner-Belegung erlauben (Hauptschalter)"

msgid "Use real pre-tune (prepare+start, faster)"
msgstr "Echtes Pre-Tune verwenden (prepare+start, schneller)"

msgid "Pre-tune NEXT channel"
msgstr "Nächsten Sender vorhalten"

msgid "Pre-tune PREVIOUS channel"
msgstr "Vorherigen Sender vorhalten"

msgid "Pre-tune LAST channel (history)"
msgstr "Zuletzt gesehenen Sender vorhalten"

msgid "Activate descrambler in NEXT pay-TV pre-tune"
msgstr "Descrambler beim nächsten Pay-TV-Vorhalten aktivieren"

msgid "Activate descrambler in PREVIOUS pay-TV pre-tune"
msgstr "Descrambler beim vorherigen Pay-TV-Vorhalten aktivieren"

msgid "Activate descrambler in LAST pay-TV pre-tune (history)"
msgstr "Descrambler beim zuletzt gesehenen Pay-TV-Vorhalten aktivieren"

msgid "Release demods when recording starts"
msgstr "Tuner freigeben bei Aufnahmestart"

msgid "Release demods when PiP starts"
msgstr "Tuner freigeben bei PiP-Start"

msgid "Show zap latency OSD"
msgstr "Umschaltzeit am Bildschirm anzeigen"

msgid "Verbose debug logging"
msgstr "Ausführliches Debug-Log"

msgid "Cancel"
msgstr "Abbrechen"

msgid "Save"
msgstr "Speichern"

msgid ""
"FBC-ChannelSpeedChange disabled itself for safety.\n"
"Reason: %s\n"
"Re-enable in Plugins after restart."
msgstr ""
"FBC-ChannelSpeedChange hat sich aus Sicherheitsgründen abgeschaltet.\n"
"Grund: %s\n"
"Nach dem Neustart unter Plugins wieder aktivieren."
